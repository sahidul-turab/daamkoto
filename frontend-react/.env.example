# DaamKoto frontend environment variables
#
# Base URL of the deployed FastAPI backend (NO trailing slash).
# - Local dev: leave this UNSET. Vite proxies /api -> http://127.0.0.1:8000
#   (see vite.config.ts), so the app talks to your local backend.
# - Production (Vercel): set this to your hosted backend, e.g.
#   VITE_API_BASE=https://daamkoto-api.onrender.com
#
# Until a backend is hosted, the deployed site will load but show no products.
VITE_API_BASE=
